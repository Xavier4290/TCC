import socket

HOST = "0.0.0.0"
PORT = 5000

arquivo = open("dados_recebidos_pc.csv", "a", encoding="utf-8")

servidor = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
servidor.bind((HOST, PORT))
servidor.listen()

print("Aguardando dados do Raspberry...")

conn, addr = servidor.accept()
print("Conectado por", addr)

while True:
    dados = conn.recv(1024)

    if not dados:
        break

    texto = dados.decode()

    arquivo.write(texto)
    arquivo.flush()

    print("Dados recebidos")

conn.close()
arquivo.close()